<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Articles</title>
</head>
<body>
    <h1>Статьи</h1>
    <a href="/articles/new">Создать статью</a>
    <ul>
        <% articles.forEach(function(article) { %>
        <li>
            <a href="/articles/<%= article.id %>"><%= article.title %></a>
        </li>
        <% }) %>
    </ul>
</body>
</html>
